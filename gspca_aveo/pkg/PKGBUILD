pkgname=gspca_aveo-dkms
pkgver=1.0
pkgrel=1
pkgdesc="AVEO Cheetah3 USB camera driver (gspca_aveo)"
arch=('x86_64')
url="https://github.com/kswit/USB_driver"
license=('GPL')
depends=('dkms')
makedepends=('git')
source=("git+https://github.com/kswit/USB_driver.git")
sha256sums=('SKIP')

package() {
    cd "$srcdir/USB_driver/gspca_aveo"

    install -dm755 "$pkgdir/usr/src/${pkgname}-${pkgver}"

    cp -r * "$pkgdir/usr/src/${pkgname}-${pkgver}/"

    # dkms.conf
    cat > "$pkgdir/usr/src/${pkgname}-${pkgver}/dkms.conf" <<EOF
PACKAGE_NAME="${pkgname}"
PACKAGE_VERSION="${pkgver}"
BUILT_MODULE_NAME[0]="gspca_aveo"
DEST_MODULE_LOCATION[0]="/kernel/drivers/media/usb/gspca"
AUTOINSTALL="yes"
EOF
}